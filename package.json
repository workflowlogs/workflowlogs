{
  "name": "n8n-nodes-workflowlogs",
  "version": "0.5.0",
  "description": "n8n community node for sending workflow logs (success/error) to WorkflowLogs monitoring platform",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "logging",
    "monitoring",
    "error-tracking"
  ],
  "license": "MIT",
  "author": {
    "name": "WorkflowLogs"
  },
  "homepage": "https://workflowlogs.com/docs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/workflowlogs/n8n-nodes-workflowlogs.git"
  },
  "main": "dist/index.js",
  "files": [
    "dist/"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/nodes/WorkflowLogs/WorkflowLogs.node.js"
    ],
    "credentials": [
      "dist/credentials/WorkflowLogsApi.credentials.js"
    ]
  },
  "scripts": {
    "build": "tsc && cp nodes/WorkflowLogs/*.svg dist/nodes/WorkflowLogs/",
    "dev": "tsc --watch",
    "lint": "eslint nodes/ credentials/ --ext .ts",
    "prepublishOnly": "npm run build",
    "release": "release-it",
    "release:dry": "release-it --dry-run",
    "release:minor": "release-it minor",
    "release:major": "release-it major"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/node": "^20.0.0",
    "n8n-workflow": "^1.0.0",
    "release-it": "^19.2.4",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  }
}
